# ============================================================
#  SecureScanner - Backend Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# REQUIRED: Change this to any long random string (32+ characters)
# Generate one by running: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars

# Token settings (leave as-is)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite - no setup needed, file created automatically)
DATABASE_URL=sqlite:///./securescanner.db

# OPTIONAL: GitHub personal access token
# Get one at: https://github.com/settings/tokens (no scopes needed for public repos)
# Required for: private repos, higher rate limits (5000 req/hr vs 60)
GITHUB_TOKEN=

# Frontend URL for CORS (don't change unless you run frontend on a different port)
FRONTEND_URL=http://localhost:5173
